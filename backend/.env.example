# Database - replace with your actual PostgreSQL password
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/apds_banking"

# JWT Secrets - use long random strings (minimum 64 characters)
JWT_SECRET="replace-with-a-very-long-random-secret-minimum-64-characters-long"
JWT_REFRESH_SECRET="replace-with-a-different-very-long-random-secret-minimum-64-chars"

# JWT Expiry
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Argon2id pepper - a secret string added before hashing passwords
ARGON2_PEPPER="replace-with-a-long-random-pepper-string-minimum-32-characters"

# Server ports
PORT=5000
HTTP_REDIRECT_PORT=5001

# Frontend URL (for CORS)
FRONTEND_URL="https://localhost:5173"

# Environment
NODE_ENV="development"
